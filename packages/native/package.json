{
  "name": "@granite-js/native",
  "version": "1.0.32",
  "description": "A native module hub package for Granite",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toss/granite.git",
    "directory": "packages/native"
  },
  "scripts": {
    "prepack": "yarn build",
    "typecheck": "tsc --noEmit",
    "test": "yarn jest",
    "lint": "eslint .",
    "build": "rm -rf dist && yarn generate-fingerprint && tsc -p tsconfig.build.json",
    "sync-packages": "tsx --import ./.scripts/sync-packages.mts",
    "generate-fingerprint": "tsx -e \"import('./.scripts/generate-fingerprint.mts').catch(e=>{console.error(e);process.exit(1)})\""
  },
  "exports": {
    "./@react-native-async-storage/async-storage": {
      "types": "./dist/@react-native-async-storage/async-storage/index.d.ts",
      "default": "./src/@react-native-async-storage/async-storage/index.ts"
    },
    "./@react-native-community/blur": {
      "types": "./dist/@react-native-community/blur.d.ts",
      "default": "./src/@react-native-community/blur.ts"
    },
    "./@react-navigation/native": {
      "types": "./dist/@react-navigation/native.d.ts",
      "default": "./src/@react-navigation/native.ts"
    },
    "./@react-navigation/native-stack": {
      "types": "./dist/@react-navigation/native-stack.d.ts",
      "default": "./src/@react-navigation/native-stack.ts"
    },
    "./@react-navigation/elements": {
      "types": "./dist/@react-navigation/elements.d.ts",
      "default": "./src/@react-navigation/elements.ts"
    },
    "./@shopify/flash-list": {
      "types": "./dist/@shopify/flash-list.d.ts",
      "default": "./src/@shopify/flash-list.ts"
    },
    "./react-native-webview": {
      "types": "./dist/react-native-webview.d.ts",
      "default": "./src/react-native-webview.ts"
    },
    "./lottie-react-native": {
      "types": "./dist/lottie-react-native.d.ts",
      "default": "./src/lottie-react-native.ts"
    },
    "./react-native-fast-image": {
      "types": "./dist/react-native-fast-image.d.ts",
      "default": "./src/react-native-fast-image.ts"
    },
    "./react-native-video": {
      "types": "./dist/react-native-video.d.ts",
      "default": "./src/react-native-video.ts"
    },
    "./react-native-safe-area-context": {
      "types": "./dist/react-native-safe-area-context/index.d.ts",
      "default": "./src/react-native-safe-area-context/index.ts"
    },
    "./react-native-safe-area-context/jest/mock": {
      "types": "./dist/react-native-safe-area-context/jest/mock.d.ts",
      "default": "./src/react-native-safe-area-context/jest/mock.ts"
    },
    "./react-native-screens": {
      "types": "./dist/react-native-screens.d.ts",
      "default": "./src/react-native-screens.ts"
    },
    "./react-native-svg": {
      "types": "./dist/react-native-svg.d.ts",
      "default": "./src/react-native-svg.ts"
    },
    "./react-native-gesture-handler": {
      "types": "./dist/react-native-gesture-handler/index.d.ts",
      "default": "./src/react-native-gesture-handler/index.ts"
    },
    "./react-native-pager-view": {
      "types": "./dist/react-native-pager-view.d.ts",
      "default": "./src/react-native-pager-view.ts"
    },
    "./react-native-gesture-handler/jestSetup": {
      "types": "./dist/react-native-gesture-handler/jestSetup.d.ts",
      "default": "./src/react-native-gesture-handler/jestSetup.js"
    },
    "./fingerprint": {
      "types": "./fingerprint/index.d.ts",
      "import": "./fingerprint/index.mjs",
      "require": "./fingerprint/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "**/*.d.ts",
    "*.d.ts",
    "src",
    "fingerprint",
    "dist"
  ],
  "dependencies": {
    "@granite-js/image": "workspace:*",
    "@granite-js/lottie": "workspace:*",
    "@granite-js/video": "workspace:*",
    "@react-native-async-storage/async-storage": "catalog:rn84",
    "@react-native-community/blur": "catalog:rn84",
    "@react-navigation/elements": "catalog:rn84",
    "@react-navigation/native": "catalog:rn84",
    "@react-navigation/native-stack": "catalog:rn84",
    "@shopify/flash-list": "catalog:rn84",
    "react-native-gesture-handler": "catalog:rn84",
    "react-native-pager-view": "catalog:rn84",
    "react-native-safe-area-context": "catalog:rn84",
    "react-native-screens": "catalog:rn84",
    "react-native-svg": "catalog:rn84",
    "react-native-webview": "catalog:rn84"
  },
  "devDependencies": {
    "@babel/core": "catalog:babel",
    "@babel/preset-env": "catalog:babel",
    "@babel/preset-typescript": "catalog:babel",
    "@babel/runtime": "catalog:babel",
    "@types/babel__core": "catalog:babel",
    "@types/babel__preset-env": "catalog:babel",
    "@types/jest": "catalog:tools",
    "@types/node": "catalog:tools",
    "@types/react": "catalog:rn84",
    "babel-jest": "catalog:tools",
    "esbuild": "catalog:tools",
    "eslint": "catalog:tools",
    "jest": "catalog:tools",
    "react": "catalog:rn84",
    "react-native": "catalog:rn84",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools",
    "zx": "catalog:tools"
  },
  "peerDependencies": {
    "@babel/runtime": "*",
    "react": "*",
    "react-native": "*"
  },
  "sideEffects": false
}
