{
  "name": "@granite-js/plugin-env",
  "type": "module",
  "version": "1.0.32",
  "license": "Apache-2.0",
  "description": "An env plugin for Granite",
  "scripts": {
    "prepack": "yarn build",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --coverage",
    "build": "tsdown"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toss/granite.git",
    "directory": "packages/plugin-env"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@babel/core": "catalog:babel",
    "@babel/types": "catalog:babel",
    "@types/babel__core": "catalog:babel",
    "@types/node": "catalog:tools",
    "@vitest/coverage-v8": "catalog:tools",
    "tsdown": "catalog:tools",
    "typescript": "catalog:tools",
    "vitest": "catalog:tools"
  },
  "dependencies": {
    "@granite-js/plugin-core": "workspace:*",
    "@granite-js/utils": "workspace:*"
  },
  "sideEffects": false
}
